rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper check
    function isAuthenticated() {
      return request.auth != null;
    }

    // User profiles rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();

      // User addresses subcollection
      match /addresses/{addressId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }

      // User notifications subcollection
      match /notifications/{notificationId} {
        allow read: if isAuthenticated() && request.auth.uid == userId;
        allow write: if isAuthenticated();
      }
    }

    // Products catalog is readable by anyone, admin can modify
    match /products/{productId} {
      allow read: if true;
      allow write: if isAuthenticated(); // Simulating administrative edits
    }

    // Categories are readable by anyone, admin can modify
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Vouchers are readable by anyone, admin can modify
    match /vouchers/{voucherId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Wishlist alerts collection
    match /wishlists/{wishlistId} {
      allow read, write: if isAuthenticated();
    }

    // Orders checkout details
    match /orders/{orderId} {
      allow create: if isAuthenticated();
      allow read, update: if true;
      allow delete: if isAuthenticated();
    }

    // Product reviews rules
    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Support tickets rules
    match /support_tickets/{ticketId} {
      allow read, write: if isAuthenticated();
    }

    // Mail triggers rules for Zoho SMTP dispatching
    match /mail_triggers/{triggerId} {
      allow create: if isAuthenticated();
      allow read, write: if isAuthenticated();
    }

    // Admin settings rules
    match /admin_settings/{settingId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
  }
}
